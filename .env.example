# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/booking_db

# Redis Configuration (Broker & Result Backend for Celery)
REDIS_URL=redis://localhost:6379/0

# Rate Limiting Storage URI (memory:// for tests, redis://... for prod)
RATE_LIMIT_STORAGE_URI=${REDIS_URL}

# Application Environment (dev, prod, test)
APP_ENV=prod

LOG_LEVEL=INFO
